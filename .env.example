# Скопируйте в .env и при необходимости измените.
#
# Порт API: 3001 по умолчанию, если фронт Next.js на 3000 (NEXT_PUBLIC_API_URL=http://localhost:3001).

# App
NODE_ENV=development
PORT=3001

# Database
# С Docker (npm run db:prepare / docker compose up -d):
#   postgresql://mathcenter:mathcenter@127.0.0.1:5432/mathcenter?schema=public
#
# Локальный Postgres без Docker (часто ваш системный пользователь без пароля):
#   postgresql://ВАШ_ЛОГИН@localhost:5432/mathcenter?schema=public
#
# На macOS + Docker Desktop надёжнее 127.0.0.1 вместо localhost (иначе бывает P1000).
DATABASE_URL="postgresql://mathcenter:mathcenter@127.0.0.1:5432/mathcenter?schema=public"

# JWT (ОБЯЗАТЕЛЬНО смените в продакшене!)
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# S3 / MinIO (для хранения файлов — используется в следующих этапах)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=mathcenter
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
