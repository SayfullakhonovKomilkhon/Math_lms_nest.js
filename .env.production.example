# ============================================================================
# Шаблон production-окружения. Скопируйте в .env.production и заполните секреты.
#   cp .env.production.example .env.production
#   nano .env.production
#
# .env.production должен быть в .gitignore! Никогда не коммитьте секреты.
# ============================================================================

# --- Домены ---
# Поддомен, на котором будет API. Caddy получит для него Let's Encrypt сертификат.
DOMAIN=api.khanovmathacademy.uz
# Email для уведомлений Let's Encrypt о просроке/проблемах с сертификатом.
ACME_EMAIL=admin@khanovmathacademy.uz
# Откуда фронт делает запросы (для CORS). Несколько origin'ов — через запятую.
FRONTEND_URL=https://khanovmathacademy.uz,https://www.khanovmathacademy.uz

# --- Postgres ---
# Эти переменные используются и Postgres-контейнером, и для DATABASE_URL в API.
POSTGRES_USER=mathcenter
POSTGRES_PASSWORD=ЗАМЕНИ_МЕНЯ_СГЕНЕРИРУЙ_openssl_rand_-base64_32
POSTGRES_DB=mathcenter

# --- JWT секреты (КРИТИЧНО!) ---
# Сгенерируйте свежие через: openssl rand -base64 64
# При смене этих секретов все юзеры разлогинятся (потребуется заново войти).
JWT_ACCESS_SECRET=ЗАМЕНИ_МЕНЯ_openssl_rand_-base64_64
JWT_REFRESH_SECRET=ЗАМЕНИ_МЕНЯ_другой_openssl_rand_-base64_64
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# --- S3 (хранение файлов) ---
# Пока не настроено — поставьте заглушки. Файлы загружаться не будут,
# но остальное API работает. После подключения DigitalOcean Spaces заполните.
S3_ENDPOINT=https://sgp1.digitaloceanspaces.com
S3_BUCKET=mathcenter-prod
S3_ACCESS_KEY=DO_SPACES_KEY_ID
S3_SECRET_KEY=DO_SPACES_SECRET
S3_REGION=sgp1

# --- Telegram bot (если используется) ---
# Токен берётся у @BotFather. Если бот не нужен — оставьте пустым.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=mathcenter_bot

# --- Прочее ---
NODE_ENV=production
